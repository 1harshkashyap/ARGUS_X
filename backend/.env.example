# ── LLM Keys ─────────────────────────────────────
GEMINI_API_KEY=your_free_gemini_key_from_aistudio.google.com
OPENAI_API_KEY=                                           # optional — only if user provides

# ── Supabase ──────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key_not_anon_key

# ── Security ──────────────────────────────────────
DASHBOARD_READ_KEY=generate_with_python_secrets_token_urlsafe_32

# ── App Settings ──────────────────────────────────
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Battle Engine ─────────────────────────────────
BATTLE_ENABLED=false
BATTLE_INTERVAL_SECONDS=60

# ── ML Classifier ─────────────────────────────────
ML_ENABLED=false
FIREWALL_ML_THRESHOLD=0.87

# ── LLM Keys ─────────────────────────────────────
GEMINI_API_KEY=your_free_gemini_key_from_aistudio.google.com
OPENAI_API_KEY=optional_only_if_user_provides_paid_key

# ── Supabase ──────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key_not_anon_key          # backend only — bypasses RLS
SUPABASE_ANON_KEY=your_anon_publishable_key               # frontend only — respects RLS

# ── App Settings ──────────────────────────────────
ENVIRONMENT=development
APP_VERSION=2.0.0

# ── Battle Engine ─────────────────────────────────
BATTLE_ENABLED=false
BATTLE_INTERVAL_SECONDS=60

# ── ML Classifier ─────────────────────────────────
ML_ENABLED=false
FIREWALL_ML_THRESHOLD=0.87
